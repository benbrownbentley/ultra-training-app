# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Supabase project URL — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable (anon) key — safe to expose to the browser; subject to RLS.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase service-role key — SERVER ONLY. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API key — SERVER ONLY. Used by lib/claude.ts to generate plans.
ANTHROPIC_API_KEY=

# Optional override for the Claude model id used by plan generation (defaults to claude-haiku-4-5).
CLAUDE_MODEL=

# Phase 2.5 feature flag. Controls whether the chunked-generation
# orchestrator runs (meta-plan + per-phase calls) instead of the
# legacy single-call generateTrainingPlan. **On by default** as of
# Phase 2.5 deploy — leave unset for normal operation. To roll back
# without a code change, set this to "false" in Vercel → Project →
# Settings → Environment Variables. Rollback is a single flag flip;
# no redeploy. See CHUNKING_SPEC.md §3.9.
PLAN_CHUNKING_ENABLED=

# Public base URL of the deployment. Used by the regen advance chain
# (lib/regen-advance-engine.ts → scheduleSelfAdvance) to fire a
# server-to-server self-fetch at /api/regen/advance after each
# phase. Set to the public URL in Production + Preview (e.g.,
# https://vert.app); in dev set to http://localhost:3000. If unset,
# the server-side self-drive is inactive and the client-driven
# advanceJob loop is the only chain driver (existing pre-batch
# behaviour, still functional but breaks if the user navigates away).
SITE_URL=

# Shared secret for server-to-server self-fetches to /api/regen/advance.
# Must be a random string ≥32 chars (e.g., `openssl rand -hex 32`).
# Set in Vercel Production + Preview env. Server-only; never exposed
# to the browser. Without it the self-drive route returns 500 and the
# chain falls back to client-driven progression.
REGEN_ADVANCE_SECRET=

# Shared secret used by the Vercel cron janitor at /api/regen/janitor.
# Vercel injects this as a Bearer token on cron requests when the env
# var is set in Production. Without it the janitor route refuses to
# run (500) and stalled jobs accumulate until the lazy client-side
# watchdog catches them at next app load. Random string ≥32 chars.
CRON_SECRET=
