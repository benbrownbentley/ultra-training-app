# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Supabase project URL — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable (anon) key — safe to expose to the browser; subject to RLS.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase service-role key — SERVER ONLY. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API key — SERVER ONLY. Used by lib/claude.ts to generate plans.
ANTHROPIC_API_KEY=

# Optional override for the Claude model id used by plan generation (defaults to claude-haiku-4-5).
CLAUDE_MODEL=

# Phase 2.5 feature flag. When "true", the chunked-generation
# orchestrator runs (meta-plan + per-phase calls) instead of the
# legacy single-call generateTrainingPlan. Defaults to off — flip on
# in dev after `npm run dev` confirms a clean local smoke, then flip
# on in production via Vercel → Project → Settings → Environment
# Variables. Rollback is a single flag flip; no redeploy. See
# CHUNKING_SPEC.md §3.9.
PLAN_CHUNKING_ENABLED=
